PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@YORCH_DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

INPUT                  = "@PROJECT_SOURCE_DIR@/include" "@YORCH_DOXYGEN_MAINPAGE@" "@YORCH_DOXYGEN_INPUT_DIR@/intro_cn.md" "@YORCH_DOXYGEN_INPUT_DIR@/wiki/en" "@YORCH_DOXYGEN_INPUT_DIR@/wiki/cn"
FILE_PATTERNS          = *.hpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = "@YORCH_DOXYGEN_MAINPAGE@"

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2
AUTOLINK_SUPPORT       = YES

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

STRIP_FROM_PATH        = "@PROJECT_SOURCE_DIR@" "@YORCH_DOXYGEN_INPUT_DIR@"
FULL_PATH_NAMES        = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
